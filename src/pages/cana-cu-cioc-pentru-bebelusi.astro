---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import keywordsData from '../../keywords.json';

export const frontmatter = {
  title: "Cana cu cioc pentru bebelusi",
  excerpt: "Cand vine vorba de cana cu cioc pentru bebelusi, parerea mea sincera e ca modelul de la Philips Avent cu varsta peste 6 luni ramane o alegere sigura si eficienta pentru majoritatea familiilor. E usor de curatat, etansa si are un cioc suficient de moale incat sa nu irite gingiile micutului.",
  image: "/images/articles/cana-cu-cioc-pentru-bebelusi.webp",
  category: "Alimentatie si Nutritie Copii",
  categorySlug: "alimentatie-nutritie-copii",
  date: "2026-02-22T10:09:07.840Z",
  modifiedDate: "2026-02-22T10:09:07.840Z",
  author: "Elena Dumitrescu",
  authorRole: "Specialist Alimentatie Infantila",
  authorBio: "Elena este nutritionist cu specializare in alimentatia copiilor mici. Testeaza si recomanda produse de hranire, biberoane si accesorii care fac diversificarea si alimentatia bebelusilor mai simpla si mai sigura."
};

const faq = [
  { question: "cat costa o cana cu cioc pentru bebelusi", answer: "Pretul unei cani cu cioc pentru bebelusi variaza intre 40 si 100 de lei, in functie de brand si materiale. Modelele simple de la branduri mai putin cunoscute costa in jur de 40-50 lei, in timp ce cele de la Philips Avent sau Tommee Tippee se situeaza intre 50 si 75 lei. Variantele premium pot depasi 100 lei." },
  { question: "care e diferenta intre cana cu cioc si pahar cu pai pentru bebelusi", answer: "Principala diferenta sta in modul de a bea: cana cu cioc imita biberonul, fortand bebelusul sa suga, ajutand la tranzitia de la biberon. Paharul cu pai ii permite sa bea prin aspiratie, dezvoltand mai mult controlul gurii, similar cu un pahar normal, dar cu riscuri mai mici de varsare. Ciocul e de obicei din silicon, paiul din plastic sau silicon." },
  { question: "cat timp se foloseste o cana cu cioc pentru bebelusi", answer: "O cana cu cioc pentru bebelusi se foloseste de obicei intre varsta de 6 luni si 18-24 de luni, sau chiar mai mult, in functie de dezvoltarea copilului. Dupa ce copilul se obisnuieste cu ea, se poate trece la pahare cu pai sau chiar la pahare normale, in functie de abilitatile sale." },
  { question: "ce cana cu cioc e mai buna pentru un nou nascut", answer: "Pentru un nou-nascut (desi majoritatea recomandarilor sunt peste 4-6 luni), se recomanda o cana cu cioc cu cioc foarte moale, din silicon, si o capacitate mica (150-200 ml). Modelele MAM Trainer Cup sunt adesea indicate pentru varste mai mici datorita ciocului extra-moale si a formei ergonomice." },
  { question: "de ce curge cana cu cioc a bebelusului meu", answer: "Daca cana cu cioc curge, cel mai probabil capacul nu este strans corect, sau o piesa de silicon (garnitura, supapa) lipseste sau este defecta. Unele modele au sisteme de ventilatie care pot permite scurgeri daca sunt manipulate incorect. Verificati intotdeauna daca toate piesele sunt la locul lor si stranse corespunzator." },
  { question: "cum sa igienizez corect o cana cu cioc", answer: "Igienizarea corecta a unei cani cu cioc implica demontarea completa a acesteia in toate componentele (cioc, capac, corp, manere, supape). Spalati-le manual cu apa calda si detergent de vase, apoi clatiti bine. Sterilizarea se poate face prin fierbere (verificati materialul) sau cu un sterilizator electric/cu aburi. Uscati-le complet inainte de a le monta la loc." },
  { question: "unde gasesc cana cu cioc pentru bebelusi ieftina", answer: "Cani cu cioc pentru bebelusi la preturi accesibile (sub 50 lei) se gasesc in magazinele mari de electronice si electrocasnice (eMag, Altex), farmacii (Catena, Sensiblu), magazinele de articole pentru copii (Bebe Tei, Noriel, Noriel Baby), dar si pe platforme online precum OLX sau la supermarketuri (Carrefour, Auchan). Verificati sectiunile de reduceri." },
  { question: "ce parere aveti de cana cu cioc Avent", answer: "Cana cu cioc Avent (Magic Cup) este, in general, foarte apreciata de parinti pentru etansarea excelenta si calitatea materialelor (silicon moale pentru cioc). Este considerata o optiune sigura si durabila, ideala pentru calatorii. Singurul minus minor ar putea fi pretul, usor mai ridicat, si uneori dificultatea de a curata dopul de silicon al ciocului." }
];

const toc = [
  { title: "Primul Meu Sau de Independenta: Recomandarea Mea de Cana cu Cioc", id: "primul-meu-sau-de-independenta-recomandarea-mea-de-cana-cu-cioc" },
  { title: "Top 5 Cani cu Cioc pentru Micii Exploratori", id: "top-5-cani-cu-cioc-pentru-micii-exploratori" },
  { title: "Cum Alegi Cana cu Cioc Potrivita pentru Micutul Tau", id: "cum-alegi-cana-cu-cioc-potrivita-pentru-micutul-tau" },
  { title: "Avent vs. Nuby: Care e Mai Buna Cana cu Cioc?", id: "avent-vs-nuby-care-e-mai-buna-cana-cu-cioc" },
  { title: "Ce Sa Eviti Cand Cumperi o Cana cu Cioc si Sfaturi de Insider", id: "ce-sa-eviti-cand-cumperi-o-cana-cu-cioc-si-sfaturi-de-insider" },
  { title: "Cana cu Cioc pe Bugete: Recomandari pentru Toate Buzunarele", id: "cana-cu-cioc-pe-bugete-recomandari-pentru-toate-buzunarele" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

