  image: "/images/articles/lampa-de-veghe-pentru-camera-copilului.webp",
  category: "Camera Copilului",
  categorySlug: "camera-copilului",
  date: "2026-01-31T16:00:00.000Z",
  modifiedDate: "2026-02-03T08:30:00.000Z",
  author: "Raluca Marin",
  authorRole: "Designer Interior Camera Copilului",
  authorBio: "Raluca are experienta in design interior pentru camere de copii si bebelusi. Recomanda mobilier, decoratiuni si accesorii care transforma camera micutului intr-un spatiu sigur, functional si placut."
};

const faq = [
  { question: "Ce tip de lumina este cel mai potrivit pentru o lampa de veghe?", answer: "Cel mai potrivit este o lumina calda, galbuie sau portocalie. Aceasta imita apusul soarelui si ajuta la producerea melatoninei, hormonul somnului. Evita lumina alba sau albastra, care poate agita copilul si poate perturba ciclul somnului." },
  { question: "Este necesara o lampa de veghe cu functii suplimentare, precum muzica sau proiectii?", answer: "Nu este neaparat necesara, dar poate fi un plus. Muzica de leagan sau proiectiile de stele pot ajuta la relaxarea copilului. Totusi, asigura-te ca volumul muzicii este scazut si ca proiectiile nu sunt prea intense pentru a nu-l agita." },
  { question: "Cat de puternica ar trebui sa fie lumina unei lampi de veghe?", answer: "Lumina trebuie sa fie blanda, suficienta cat sa te poti orienta in camera, dar nu atat de puternica incat sa deranjeze copilul. Ideal este sa poti regla intensitatea luminii, pentru a o adapta nevoilor tale." },
  { question: "Ce risc exista daca folosesc o lampa de veghe prea puternica?", answer: "O lumina prea puternica, mai ales daca este rece, poate inhiba producerea de melatonina si poate face copilul sa se simta agitat in loc sa se relaxeze. De asemenea, poate crea umbre intunecate care il pot speria pe cel mic." },
  { question: "Cat de des trebuie sa curat lampa de veghe?", answer: "Recomandarea mea este sa o cureti usor o data pe saptamana, sau ori de cate ori observi ca s-a adunat praf. Un praf excesiv poate reduce intensitatea luminii si nu este igienic." },
  { question: "Ce fac daca lampa de veghe pe baterii nu mai functioneaza?", answer: "Verifica mai intai daca bateriile sunt descarcate si inlocuieste-le. Daca problema persista, poate fi vorba de o defectiune a aparatului. Daca lampa este inca in garantie, poti incerca sa o returnezi sau sa o schimbi." }
];

const toc = [
  { title: "De ce conteaza alegerea corecta a unei lampi de veghe", id: "de-ce-conteaza-alegerea-corecta-a-unei-lampi-de-veghe" },
  { title: "Top recomandari de lampi de veghe – ce am incercat eu", id: "top-recomandari-de-lampi-de-veghe--ce-am-incercat-eu" },
  { title: "Cum alegi corect lampa de veghe potrivita", id: "cum-alegi-corect-lampa-de-veghe-potrivita" },
  { title: "Avantaje si dezavantaje – o analiza sincera", id: "avantaje-si-dezavantaje--o-analiza-sincera" },
  { title: "Sfaturi practice din experienta mea – trucuri si greseli de evitat", id: "sfaturi-practice-din-experienta-mea--trucuri-si-greseli-de-evitat" },
  { title: "Parerea mea finala – ce recomand si de ce", id: "parerea-mea-finala--ce-recomand-si-de-ce" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
