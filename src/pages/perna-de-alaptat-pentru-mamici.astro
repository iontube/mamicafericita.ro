};

const faq = [
  { question: "Cat costa o perna de alaptat buna?", answer: "O perna de alaptat pentru mamici de calitate decenta, cu vatelina buna si husa detasabila, costa intre 150 si 280 de lei. Modelele premium, umplute cu microbile, pot ajunge si la 350-400 de lei. Cele foarte ieftine, sub 100 de lei, sunt de obicei de proasta calitate." },
  { question: "Care e diferenta intre perna de alaptat cu microbile si cea cu vatelina?", answer: "Perna cu microbile se muleaza perfect pe corp, oferind sustinere constanta si personalizata, fiind si foarte durabila. Perna cu vatelina este mai moale initial, dar vatelina se poate turti in timp, pierzand din suport. Microbilele sunt mai scumpe, dar mai eficiente pe termen lung." },
  { question: "Merita sa cumpar o perna de alaptat daca alaptez rar?", answer: "Da, merita chiar si daca alaptezi rar. O perna de alaptat nu e utila doar pentru alaptat, ci si pentru a sustine bebelusul cand sta in brate, pentru relaxare in sarcina, sau ca \"cuib\" pentru bebe mai mare. Oferta confort sporit pentru tine si siguranta pentru cel mic." },
  { question: "Ce perna de alaptat e mai buna pentru mamici cu probleme de spate?", answer: "Pentru mamici cu probleme de spate, cele mai indicate sunt pernele cu microbile sau cele cu umplutura densa, care ofera un suport solid si ergonomic. Forma de U inversat, care inconjoara talia, este de asemenea ideala pentru a corecta postura si a reduce presiunea pe coloana." },
  { question: "De ce se turteste perna de alaptat cu vatelina?", answer: "Perna de alaptat cu vatelina se turteste din cauza presiunii constante si a miscarii. Fibrele din vatelina se comprima in timp, pierzandu-si volumul si elasticitatea. Vatelina de calitate inferioara se turteste mult mai repede decat cea de calitate superioara." },
  { question: "Cum se spala corect o perna de alaptat?", answer: "Ideal este sa ai o perna de alaptat pentru mamici cu husa detasabila si lavabila. Aceasta se spala conform instructiunilor de pe eticheta, de obicei la 30-40 de grade. Perna in sine, daca nu este specificat altfel, se curata prin stergere cu o carpa umeda. Evita sa bagi in masina de spalat pernele umplute cu microbile sau cu vatelina fara husa detasabila." },
  { question: "Unde gasesc perna de alaptat de calitate in Romania?", answer: "Perni de alaptat de calitate se gasesc in magazinele online specializate in produse pentru bebelusi si mamici (ex. BebeTei, Noriel, Emag), in marile magazine de articole pentru copii, dar si pe site-uri dedicate produselor de puericultura. Verifica atat brandurile cunoscute, cat si ofertelor din magazinele mai mici." },
  { question: "Pot folosi o perna normala pe post de perna de alaptat?", answer: "Nu, o perna normala nu ofera acelasi suport si confort ca o perna de alaptat pentru mamici dedicata. Pernutele obisnuite sunt prea moi sau prea tari, nu au forma ergonomica necesara pentru a sustine corect atat mama, cat si copilul in timpul alaptarii, putand cauza disconfort si dureri." }
];

const toc = [
  { title: "Alo, mamico, asta-i perna de alaptat care iti trebuie!", id: "alo-mamico-asta-i-perna-de-alaptat-care-iti-trebuie" },
  { title: "Top 5 Perna de Alaptat: Pareri Sincere si Preturi (Lei)", id: "top-5-perna-de-alaptat-pareri-sincere-si-preturi-lei" },
  { title: "Cum Alegi Perna de Alaptat Potrivita: Ghidul Prietenei Tale", id: "cum-alegi-perna-de-alaptat-potrivita-ghidul-prietenei-tale" },
  { title: "Perna de Alaptat vs. Perna Normala: Ce Alegi?", id: "perna-de-alaptat-vs-perna-normala-ce-alegi" },
  { title: "Greșeli de Evitat și Secrete de Mamici cu Perna de Alaptat", id: "greseli-de-evitat-si-secrete-de-mamici-cu-perna-de-alaptat" },
  { title: "Verdict: Perna de Alaptat pe Bugete Reale (Lei)", id: "verdict-perna-de-alaptat-pe-bugete-reale-lei" }
