};

const faq = [
  { question: "Cand e cel mai bun moment sa incep sa folosesc crema antivergeturi?", answer: "Cel mai bun moment este chiar de la inceputul sarcinii, ideal din prima luna sau cand incepi sa observi ca burtica incepe sa creasca. Astfel, pielea ta va fi pregatita sa se intinda si va fi mai bine hidratata si elastica." },
  { question: "Pot folosi aceeasi crema antivergeturi pentru corp si pentru sani?", answer: "Da, majoritatea cremelor antivergeturi sunt potrivite pentru toate zonele predispuse la vergeturi, inclusiv sanii. Totusi, verifica intotdeauna eticheta produsului si prefera formulele blande, testate dermatologic." },
  { question: "Exista ingrediente pe care ar trebui sa le evit in cremele antivergeturi?", answer: "Este recomandat sa eviti parabenzii, ftalatii, colorantii artificiali si parfumurile sintetice puternice, mai ales daca ai pielea sensibila. Cauta produse cu ingrediente naturale, blande si sigure pentru sarcina." },
  { question: "Cat de des trebuie sa aplic crema antivergeturi?", answer: "Ideal, crema antivergeturi trebuie aplicata de doua ori pe zi, dimineata si seara, dupa ce ai facut dus, pe pielea curata si usor umeda. Masajul usor ajuta la absorbtie." },
  { question: "Ce fac daca am deja vergeturi? Mai ajuta crema?", answer: "Da, cremele antivergeturi pot ajuta si la estomparea vergeturilor deja existente, mai ales daca sunt folosite consecvent. Nu le vor face sa dispara complet, dar le pot face mai putin vizibile si imbunatati aspectul pielii." },
  { question: "Uleiul de migdale dulci este suficient pentru prevenirea vergeturilor?", answer: "Uleiul de migdale dulci este o optiune excelenta, naturala si accesibila, care hidrateaza si imbunatateste elasticitatea pielii. Pentru multe mamici, este suficient, mai ales in primele luni. Daca pielea ta este insa foarte uscata sau predispusa la vergeturi, poti opta pentru o formula mai bogata sau sa il combini cu o crema." }
];

const toc = [
  { title: "De ce conteaza alegerea corecta a cremei antivergeturi", id: "de-ce-conteaza-alegerea-corecta-a-cremei-antivergeturi" },
  { title: "Top recomandari de creme antivergeturi testate de mine", id: "top-recomandari-de-creme-antivergeturi-testate-de-mine" },
  { title: "Cum alegi corect crema antivergeturi pentru tine", id: "cum-alegi-corect-crema-antivergeturi-pentru-tine" },
  { title: "Avantaje si dezavantaje ale utilizarii cremelor antivergeturi", id: "avantaje-si-dezavantaje-ale-utilizarii-cremelor-antivergeturi" },
  { title: "Sfaturi practice din experienta mea de mamica", id: "sfaturi-practice-din-experienta-mea-de-mamica" },
  { title: "Parerea mea finala despre crema antivergeturi pentru sarcina", id: "parerea-mea-finala-despre-crema-antivergeturi-pentru-sarcina" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
