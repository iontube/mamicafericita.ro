import keywordsData from '../../keywords.json';

export const frontmatter = {
  title: "Biberon anticolici pentru bebelusi",
  excerpt: "Daca bebelusul tau se chinuie cu gaze si colici, cel mai bun biberon anticolici pentru bebelusi este cel cu un sistem de ventilatie performant, care reduce semnificativ inghitirea aerului. Modelele de la Dr. Brown's si Philips Avent sunt printre cele mai apreciate, insa alegerea potrivita depinde si de preferintele copilului.",
  image: "/images/articles/biberon-anticolici-pentru-bebelusi.webp",
  category: "Alimentatie si Nutritie Copii",
  categorySlug: "alimentatie-nutritie-copii",
  date: "2026-02-10T10:08:41.004Z",
  modifiedDate: "2026-02-10T10:08:41.004Z",
  author: "Elena Dumitrescu",
  authorRole: "Specialist Alimentatie Infantila",
  authorBio: "Elena este nutritionist cu specializare in alimentatia copiilor mici. Testeaza si recomanda produse de hranire, biberoane si accesorii care fac diversificarea si alimentatia bebelusilor mai simpla si mai sigura."
};

const faq = [
  { question: "cat costa un biberon anticolici bun?", answer: "Un biberon anticolici pentru bebelusi bun costa intre 40 si 70 lei pe bucata. Modelele mai accesibile se gasesc de la 30 lei, in timp ce cele premium, precum Dr. Brown's, ajung la 60-70 lei. Pretul poate varia in functie de brand, numar de piese si oferte." },
  { question: "care e diferenta intre un biberon normal si unul anticolici?", answer: "Diferenta principala consta in sistemul de ventilatie. Un biberon anticolici pentru bebelusi are o canula sau o valva speciala care permite aerului sa iasa din biberon, reducand astfel cantitatea de aer inghitita de copil in timpul hranirii. Un biberon normal nu are acest sistem, crescand riscul de gaze si colici." },
  { question: "merita sa cumpar biberoane anticolici pentru nou nascuti?", answer: "Da, merita sa cumperi biberoane anticolici pentru bebelusi, mai ales daca alaptezi la biberon sau daca bebelusul manifesta deja semne de colici. Aceste biberoane ajuta la reducerea acumularii de gaze, previn refluxul si disconfortul abdominal, facand hranirea mai placuta pentru copil." },
  { question: "ce biberon anticolici e mai bun Dr. Brown's sau Avent?", answer: "Dr. Brown's este considerat mai eficient pentru colici severe datorita sistemului complex cu canula, dar este greu de curatat. Philips Avent are un sistem mai simplu cu valva in tetina, usor de curatat si eficient pentru colici moderate. Alegerea depinde de severitatea colicilor si de preferinta pentru usurinta in curatare." },
  { question: "de ce se infunda tetina la biberonul anticolici?", answer: "Tetina unui biberon anticolici pentru bebelusi se poate infunda din cauza reziduurilor de lapte uscate, mai ales daca nu este curatata imediat dupa utilizare. De asemenea, sistemul de ventilatie se poate bloca daca nu este curatat corect, afectand fluxul de lapte si eficienta anticolici." },
  { question: "cum sa curat corect un biberon anticolici?", answer: "Curatarea corecta a unui biberon anticolici pentru bebelusi presupune dezasamblarea completa a tuturor pieselor. Foloseste o perie speciala pentru a curata canula, tubul si tetina. Sterilizeaza piesele prin fierbere sau cu un sterilizator. Verifica instructiunile specifice ale fiecarui model." },
  { question: "unde gasesc biberoane anticolici originale?", answer: "Poti gasi biberoane anticolici pentru bebelusi originale in farmacii mari, magazine pentru copii (Noriel, Bebe Tei, eMag Baby), supermarketuri cu departament de produse pentru copii si pe site-urile oficiale ale producatorilor. Verifica mereu ambalajul si cauta sigle de autenticitate." },
  { question: "ce flux de tetina anticolici sa aleg pentru un bebelus de 2 luni?", answer: "Pentru un bebelus de 2 luni, se recomanda de obicei un flux mediu (flux 2). Majoritatea brandurilor de biberoane anticolici pentru bebelusi ofera tetine cu flux lent (flux 1) pentru nou-nascuti si flux mediu (flux 2) pentru 1-3 luni. Verifica ghidul de varsta al producatorului." }
];

const toc = [
  { title: "Biberonul Anticolici Perfect: Cum Alegi Fara Sa Dau Cu Banul", id: "biberonul-anticolici-perfect-cum-alegi-fara-sa-dau-cu-banul" },
  { title: "Top Recomandari Biberon Anticolici: Partea Mea De Experienta Si Minusuri", id: "top-recomandari-biberon-anticolici-partea-mea-de-experienta-si-minusuri" },
  { title: "Ce Sa Uiti Sa Nu Faci Cand Alegi Biberon Anticolici", id: "ce-sa-uiti-sa-nu-faci-cand-alegi-biberon-anticolici" },
  { title: "Dr. Brown's vs. Philips Avent: Duelul Titanilor Anticolici", id: "dr-browns-vs-philips-avent-duelul-titanilor-anticolici" },
  { title: "Pazeste-te De Capcane: Greșeli Comune La Alegerea Biberonului Anticolici", id: "pazeste-te-de-capcane-greseli-comune-la-alegerea-biberonului-anticolici" },
  { title: "Verdict Pe Buget: Biberon Anticolici Pentru Fiecare Buzunar", id: "verdict-pe-buget-biberon-anticolici-pentru-fiecare-buzunar" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
