};

const faq = [
  { question: "Este salteaua inclusa mereu de calitate?", answer: "Nu neapărat. Calitatea saltelei incluse poate varia considerabil. Este esențial să te informezi despre materialele din care este confecționată salteaua, densitatea și fermitatea ei. Caută descrieri detaliate și recenzii de la alți părinți." },
  { question: "Ce dimensiuni au, in general, patuturile cu saltea inclusa?", answer: "Majoritatea patuturilor standard au dimensiuni interioare de 120x60 cm, iar cele mai mari sunt de 140x70 cm. Salteaua inclusa va avea aceleasi dimensiuni pentru a se potrivi perfect in patut." },
  { question: "Pot cumpara patutul si salteaua separat, daca nu sunt multumita de cea inclusa?", answer: "Da, bineinteles. Daca decizi ca salteaua inclusa nu corespunde nevoilor tale, o poti inlocui oricand cu alta achizitionata separat, atata timp cat se potriveste perfect dimensiunilor patutului." },
  { question: "Ce garantie am pentru un patut cu saltea inclusa?", answer: "Garantia se aplica, de obicei, intregului pachet. Este recomandat sa verifici politica de garantie a producatorului sau a magazinului pentru a sti exact ce acoperire ai, atat pentru patut, cat si pentru saltea." },
  { question: "Este igienic sa folosesc o saltea care a venit cu patutul?", answer: "Da, daca salteaua este noua si sigilata. Este recomandat sa o aerisesti bine inainte de prima utilizare si sa folosesti intotdeauna o husa de saltea impermeabila pentru a mentine igiena pe termen lung." },
  { question: "Ce tip de saltea este cel mai recomandat pentru un nou-nascut?", answer: "Pentru nou-nascuti, se recomanda o saltea ferma, care ofera un suport bun. Materialele precum spuma poliuretanica de inalta densitate, cocosul sau latexul sunt optiuni bune. Evita saltelele prea moi." }
];

const toc = [
  { title: "De ce conteaza alegerea corecta a patutului pentru bebelus", id: "de-ce-conteaza-alegerea-corecta-a-patutului-pentru-bebelus" },
  { title: "Top recomandari de patuturi cu saltea inclusa", id: "top-recomandari-de-patuturi-cu-saltea-inclusa" },
  { title: "Cum alegi corect un patut bebe cu saltea inclusa", id: "cum-alegi-corect-un-patut-bebe-cu-saltea-inclusa" },
  { title: "Avantaje si dezavantaje ale patuturilor cu saltea inclusa", id: "avantaje-si-dezavantaje-ale-patuturilor-cu-saltea-inclusa" },
  { title: "Sfaturi practice din experienta mea", id: "sfaturi-practice-din-experienta-mea" },
  { title: "Parerea mea finala despre \"patut bebe cu saltea inclusa\"", id: "parerea-mea-finala-despre-patut-bebe-cu-saltea-inclusa" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
