import keywordsData from '../../keywords.json';

export const frontmatter = {
  title: "Carte interactiva pentru bebelusi",
  excerpt: "Daca vrei o carte interactiva pentru bebelusi care chiar sa le capteze atentia si sa-i ajute sa invete, uite care-i treaba: cele din material textil, cu texturi variate si elemente senzoriale (clopotei, zdranganele, oglinzi sigure), sunt de departe cele mai potrivite pentru primii ani. Modelele de la Little Dutch sau Lamaze sunt cam ce cauti, la preturi decente.",
  image: "/images/articles/carte-interactiva-pentru-bebelusi.webp",
  category: "Jucarii Educative",
  categorySlug: "jucarii-educative",
  date: "2026-03-04T14:51:38.309Z",
  modifiedDate: "2026-03-04T14:51:38.309Z",
  author: "Maria Ionescu",
  authorRole: "Expert Jucarii si Dezvoltare Copii",
  authorBio: "Maria este educatoare cu experienta de 8 ani in invatamantul prescolar. Se ocupa de recenzii pentru jucarii educative si materiale de dezvoltare care stimuleaza creativitatea si inteligenta copiilor."
};

const faq = [
  { question: "Cat costa o carte interactiva pentru bebelusi?", answer: "Preturile pentru o carte interactiva pentru bebelusi variaza mult. Cele simple, din material textil, fara elemente electronice, pot costa intre 50 si 100 lei. Cartile cu elemente sonore sau electronice, de la branduri cunoscute, pot ajunge intre 80 si 200 lei, uneori chiar mai mult pentru modele premium." },
  { question: "Ce diferenta e intre o carte interactiva textila si una electronica?", answer: "Cartea textila se bazeaza pe senzatii tactile, vizuale si auditive simple (fosnete, clopotei), fiind sigura si calmanta. Cartea electronica are butoane, lumini, melodii si sunete, oferind o stimulare multi-senzoriala mai intensa, dar poate fi supra-stimulativa si necesita baterii." },
  { question: "Merita sa cumpar o carte interactiva pentru bebelusi sub 6 luni?", answer: "Da, merita! Pentru bebelusii sub 6 luni, cele mai potrivite sunt cartile textile cu contrast puternic (alb-negru, rosu-alb), texturi variate si elemente senzoriale simple. Acestea stimuleaza vederea, simtul tactil si ajuta la dezvoltarea cognitivă timpurie." },
  { question: "Ce carte interactiva pentru bebelusi e mai buna pentru dezvoltarea limbajului?", answer: "Pentru dezvoltarea limbajului, o carte interactiva pentru bebelusi care prezinta imagini clare ale obiectelor sau animalelor cunoscute, insotite de numele lor si, ideal, de sunetele specifice (ex: o carte electronica cu sunete de animale), este foarte utila. Implicarea parintelui in \"citire\" e cruciala." },
  { question: "De ce sunt importante cartile interactive cu texturi diferite?", answer: "Cartile cu texturi diferite sunt esentiale pentru ca bebelusii invata prin explorare tactila. Diferitele suprafete (moi, aspre, lucioase, fosnitoare) ii ajuta sa-si dezvolte simtul tactil, sa distinga proprietatile obiectelor si sa-si stimuleze neuronii." },
  { question: "Cum sa curat o carte interactiva din material textil?", answer: "Majoritatea cartilor interactive textile pot fi curatate conform instructiunilor producatorului. De obicei, se pot spala la masina de spalat pe un program delicat, la temperatura joasa, sau manual cu apa calduta si detergent delicat. Verificati eticheta produsului." },
  { question: "Unde gasesc cele mai bune oferte la carti interactive pentru bebelusi?", answer: "Cele mai bune oferte la carti interactive pentru bebelusi le gasiti in magazinele online mari de articole pentru copii (ex: eMag, Noriel, Toys\"R\"Us), pe site-urile brandurilor direct, sau in supermarketurile cu sectiune de jucarii. Urmariti perioadele de reduceri si ofertele speciale." },
  { question: "Ce riscuri prezinta o carte interactiva electronica pentru bebelusi?", answer: "Riscurile principale ale unei carti interactive electronice sunt supra-stimularea (care poate agita copilul), prezenta pieselor mici care se pot desprinde (daca nu e de calitate), si dependenta de baterii. De asemenea, volumul prea mare poate afecta auzul." }
];

const toc = [
  { title: "Ce carte interactiva pentru bebelusi chiar merita investitia?", id: "ce-carte-interactiva-pentru-bebelusi-chiar-merita-investitia" },
  { title: "Top 5 carti interactive pentru bebelusi – De la clasice la inovatoare", id: "top-5-carti-interactive-pentru-bebelusi--de-la-clasice-la-inovatoare" },
  { title: "Cum alegi cartea interactiva pentru bebelusi potrivita – Ghidul mamei experimentate", id: "cum-alegi-cartea-interactiva-pentru-bebelusi-potrivita--ghidul-mamei-experimentate" },
  { title: "Comparatie: Carte Textila vs. Carte Electronica pentru Bebe", id: "comparatie-carte-textila-vs-carte-electronica-pentru-bebe" },
  { title: "Greșeli frecvente când cumperi o carte interactivă pentru bebeluși și sfaturi de „insider”", id: "greseli-frecvente-cand-cumperi-o-carte-interactiva-pentru-bebelusi-si-sfaturi-de-insider" },
  { title: "Recomandări de carte interactivă pentru bebeluși pe categorii de buget", id: "recomandari-de-carte-interactiva-pentru-bebelusi-pe-categorii-de-buget" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

