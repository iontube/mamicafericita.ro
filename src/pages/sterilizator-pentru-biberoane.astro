  date: "2026-02-20T10:09:21.102Z",
  modifiedDate: "2026-02-20T10:09:21.102Z",
  author: "Elena Dumitrescu",
  authorRole: "Specialist Alimentatie Infantila",
  authorBio: "Elena este nutritionist cu specializare in alimentatia copiilor mici. Testeaza si recomanda produse de hranire, biberoane si accesorii care fac diversificarea si alimentatia bebelusilor mai simpla si mai sigura."
};

const faq = [
  { question: "cat costa un sterilizator pentru biberoane", answer: "Un sterilizator pentru biberoane de microunde costa intre 100 si 200 lei. Sterilizatoarele electrice simple, fara uscare, incep de la 250 lei si pot ajunge pana la 350 lei. Modelele electrice performante, cu functie de uscare, pornesc de la 380 lei si pot depasi 500 lei." },
  { question: "care e diferenta intre sterilizator electric si cel de microunde", answer: "Sterilizatorul electric functioneaza pe baza de aburi si are adesea functie de uscare, fiind mai convenabil si sigur, dar mai scump si voluminos. Cel de microunde este rapid si ieftin, ideal pentru calatorii, dar necesita atentie sporita la manipularea aburului fierbinte si nu usuca biberoanele." },
  { question: "merita sa cumpar sterilizator pentru biberoane", answer: "Da, un sterilizator pentru biberoane merita din plin, mai ales in primele luni de viata ale bebelusului. Asigura o igiena maxima, eliminand 99.9% din bacterii, si economiseste timp pretios pentru parinti, comparativ cu fierberea clasica." },
  { question: "ce sterilizator pentru biberoane e mai bun", answer: "Cel mai bun sterilizator pentru biberoane depinde de nevoile tale: modelele electrice de la Philips Avent sau Dr. Brown's cu functie de uscare sunt considerate cele mai bune pentru confort si eficienta, dar cele de microunde sunt excelente pentru viteza si buget." },
  { question: "de ce sa sterilizez biberoanele", answer: "Sterilizarea biberoanelor este esentiala pentru a proteja sistemul imunitar inca fragil al bebelusului de bacterii si virusuri nocive. Acest proces indeparteaza eficient germenii care pot cauza probleme digestive sau infectii." },
  { question: "cum folosesc sterilizator pentru biberoane de microunde", answer: "Adauga cantitatea de apa specificata in baza sterilizatorului, aseaza biberoanele si accesoriile in el, inchide capacul si introdu-l in cuptorul cu microunde pentru 2-4 minute la putere mare. Apoi, asteapta cateva minute sa se raceasca aburul inainte de a-l deschide cu grija." },
  { question: "cat timp trebuie sa sterilizez biberoanele", answer: "In primele 6 luni de viata ale bebelusului, se recomanda sterilizarea biberoanelor dupa fiecare utilizare. Dupa varsta de 6 luni, cand sistemul imunitar este mai dezvoltat, sterilizarea poate fi facuta o data pe zi sau chiar mai rar, in functie de igiena generala." },
  { question: "unde gasesc sterilizator pentru biberoane ieftin", answer: "Sterilizatoare pentru biberoane ieftine, in special cele de microunde, se gasesc la preturi accesibile in magazinele online mari precum Emag, Noriel, Bebe Tei sau magazinele fizice de produse pentru copii. Preturi sub 200 lei sunt comune pentru modelele de baza." }
];

const toc = [
  { title: "Sterilizatorul de biberoane: cel mai rapid mod de a scapa de microbi", id: "sterilizatorul-de-biberoane-cel-mai-rapid-mod-de-a-scapa-de-microbi" },
  { title: "Top recomandari: Sterilizatoare pentru biberoane care merita banii", id: "top-recomandari-sterilizatoare-pentru-biberoane-care-merita-banii" },
  { title: "Cum sa alegi cel mai bun sterilizator pentru biberoane pentru tine", id: "cum-sa-alegi-cel-mai-bun-sterilizator-pentru-biberoane-pentru-tine" },
  { title: "Sterilizator electric vs. sterilizator pentru microunde: care e mai bun?", id: "sterilizator-electric-vs-sterilizator-pentru-microunde-care-e-mai-bun" },
  { title: "Greseli frecvente si sfaturi de parinte experimentat despre sterilizator", id: "greseli-frecvente-si-sfaturi-de-parinte-experimentat-despre-sterilizator" },
  { title: "Sterilizator pentru biberoane: recomandari pe categorii de pret", id: "sterilizator-pentru-biberoane-recomandari-pe-categorii-de-pret" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
