const faq = [
  { question: "cat costa o saltea buna pentru patut copii", answer: "O saltea pentru patut copii buna, care ofera fermitate, respirabilitate si este realizata din materiale sigure, costa in general intre 300 si 600 lei. Modelele mai ieftine, sub 300 lei, pot fi din spuma de densitate mai mica, iar cele premium, peste 600 lei, includ materiale naturale precum cocosul, latexul si huse de calitate superioara." },
  { question: "care e diferenta intre saltea cocos si saltea spuma", answer: "Salteaua din cocos este mai naturala, mai respirabila si mai rezistenta la umezeala, ideala pentru a mentine un mediu uscat si racoros. Salteaua din spuma poliuretanica, daca e de inalta densitate, ofera un suport ferm si este mai accesibila ca pret, dar poate retine mai multa caldura si umezeala." },
  { question: "merita sa iau saltea cu cocos pentru patut copii", answer: "Da, merita sa iei o saltea pentru patut copii cu cocos daca bugetul iti permite si cauti cele mai bune conditii de somn pentru bebelus. Materialul natural ofera o respirabilitate excelenta, previne supraincalzirea si are proprietati hipoalergenice, contribuind la un somn sanatos si odihnitor." },
  { question: "ce saltea e mai buna pentru nou nascuti", answer: "Pentru nou-nascuti, cea mai buna saltea este una ferma, cu suport bun pentru coloana vertebrala, confectionata din materiale hipoalergenice si respirabile. Modelele cu miez de cocos sau spuma poliuretanica de inalta densitate (minim 25 kg/m³) sunt recomandate, evitandu-se saltelele prea moi sau cele din spuma cu memorie." },
  { question: "de ce trebuie sa fie salteaua ferma pentru bebelusi", answer: "Salteaua ferma este esentiala pentru bebelusi pentru a preveni riscul de sufocare, permitandu-le sa respire liber chiar daca se intorc pe burta. De asemenea, ofera suportul corect pentru dezvoltarea sanatoasa a coloanei vertebrale, prevenind deformarile." },
  { question: "cum sa cureti salteaua de patut copii", answer: "Curatarea saltelei de patut copii se face in principal prin stergerea zonelor murdare cu o carpa umeda si putin sapun neutru, urmata de clatire si uscare completa. Daca salteaua are husa detasabila, aceasta se poate spala conform instructiunilor producatorului, de preferat la 40 de grade Celsius." },
  { question: "unde gasesc saltea pentru patut copii de calitate", answer: "O saltea pentru patut copii de calitate o poti gasi in magazinele specializate pentru bebelusi si copii, atat online, cat si fizic. De asemenea, marile magazine cu articole pentru casa sau supermarketurile cu raioane dedicate copiilor pot oferi optiuni bune, insa este important sa verifici atent specificatiile si parerile altor parinti." },
  { question: "ce inseamna saltea pentru patut copii hipoalergenica", answer: "O saltea hipoalergenica pentru patutul copilului este realizata din materiale care minimizeaza riscul de a declansa reactii alergice. Acestea includ adesea fibre naturale precum bumbacul organic, cocosul sau latexul natural, si sunt tratate pentru a respinge acarienii si bacteriile, asigurand un mediu de somn mai curat." }
];

const toc = [
  { title: "Alegerea ideala: Ce saltea pentru patut copii sa cumperi pentru un somn odihnitor", id: "alegerea-ideala-ce-saltea-pentru-patut-copii-sa-cumperi-pentru-un-somn-odihnitor" },
  { title: "Top 5 saltele pentru patut copii: Recomandari testate si verificate (cu plusuri si minusuri reale)", id: "top-5-saltele-pentru-patut-copii-recomandari-testate-si-verificate-cu-plusuri-si-minusuri-reale" },
  { title: "Cum sa alegi salteaua pentru patut copii perfecta: Ghid practic pentru parinti", id: "cum-sa-alegi-salteaua-pentru-patut-copii-perfecta-ghid-practic-pentru-parinti" },
  { title: "Saltea cu cocos vs. spuma: Ce alegi pentru patutul copilului tau?", id: "saltea-cu-cocos-vs-spuma-ce-alegi-pentru-patutul-copilului-tau" },
  { title: "Greseli de evitat la achizitionarea unei saltele pentru patut copii si sfaturi de \"insider\"", id: "greseli-de-evitat-la-achizitionarea-unei-saltele-pentru-patut-copii-si-sfaturi-de-insider" },
  { title: "Verdict pe buget: Cea mai buna saltea pentru patut copii in functie de cati lei ai la dispozitie", id: "verdict-pe-buget-cea-mai-buna-saltea-pentru-patut-copii-in-functie-de-cati-lei-ai-la-dispozitie" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

