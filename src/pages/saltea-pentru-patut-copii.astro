---
import Layout from '../layouts/Layout.astro';
import SimilarArticles from '../components/SimilarArticles.astro';
import keywordsData from '../../keywords.json';

export const frontmatter = {
  title: "Saltea pentru patut copii",
  excerpt: "Pe scurt, cea mai buna saltea pentru patut copii este una care ofera un suport ferm si uniform, confectionata din materiale hipoalergenice si respirabile. Daca ar fi sa recomand una, as merge pe o saltea cu miez de spuma poliuretanica de inalta densitate, acoperita cu o husa detasabila din bumbac organic, la un pret in jur de 300-500 lei. Asta pentru ca ofera un echilibru bun intre confort, siguranta si durabilitate pentru bebelusul tau.",
  image: "/images/articles/saltea-pentru-patut-copii.webp",
  category: "Camera Copilului",
  categorySlug: "camera-copilului",
  date: "2026-02-07T10:08:58.035Z",
  modifiedDate: "2026-02-07T10:08:58.035Z",
