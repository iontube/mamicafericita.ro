          <article class="product-review" id="ulei-de-cocos-natura-viva---200ml">
            <div class="product-review__header">
              <span class="section-tag">Raport Calitate-Pret</span>
              <h3>Ulei de Cocos "Natura Viva" - 200ml</h3>
              <div class="product-review__specs-grid">
              <div class="product-review__spec">
                <strong>Varsta recomandata</strong>De la nastere (pentru bebelusi), pe toata durata sarcinii (pentru mamici)
              </div>
              <div class="product-review__spec">
                <strong>Material</strong>100% ulei de cocos virgin organic, obtinut prin presare la rece
              </div>
              <div class="product-review__spec">
                <strong>Dimensiuni</strong>200ml (borcan)
              </div>
              <div class="product-review__spec">
                <strong>Greutate</strong>Aprox. 200g (produsul in sine)
              </div>
              <div class="product-review__spec">
                <strong>Siguranta</strong>Certificat Bio, fara aditivi, conservanti sau parfumuri
              </div>
              </div>
