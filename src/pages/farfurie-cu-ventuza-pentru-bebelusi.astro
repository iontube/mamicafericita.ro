const toc = [
  { title: "Farfurie din Silicon cu Ventuza si Lingurita Beaba Babycook", id: "farfurie-din-silicon-cu-ventuza-si-lingurita-beaba-babycook" },
  { title: "Farfurie cu Ventuza pentru Bebelusi EZPZ Mini Mat", id: "farfurie-cu-ventuza-pentru-bebelusi-ezpz-mini-mat" },
  { title: "Farfurie cu Ventuza & Capac pentru Bebelusi Liewood Albert", id: "farfurie-cu-ventuza--capac-pentru-bebelusi-liewood-albert" },
  { title: "Farfurie cu Ventuza si Suport din Bambus pentru Bebelusi Mushie", id: "farfurie-cu-ventuza-si-suport-din-bambus-pentru-bebelusi-mushie" },
  { title: "Set Farfurie, Bol si Bavetica cu Maneci din Silicon cu Ventuza - OKBaby", id: "set-farfurie-bol-si-bavetica-cu-maneci-din-silicon-cu-ventuza---okbaby" },
  { title: "Farfurie din Silicon cu Ventuza si Suport din Lemn Natural - Brand Generic", id: "farfurie-din-silicon-cu-ventuza-si-suport-din-lemn-natural---brand-generic" },
  { title: "Comparatie", id: "comparatie" },
  { title: "Cum alegi cea mai buna farfurie cu ventuza pentru bebelusi?", id: "ghid" },
  { title: "Intrebari Frecvente", id: "faq" }
