};

const faq = [
  { question: "cat costa un termos bun pentru mancare bebelusi", answer: "Un termos pentru mancare bebelusi bun, din inox si cu izolare termica eficienta, costa in general intre 60 si 120 de lei. Modelele mai ieftine, sub 50 de lei, pot avea performante termice limitate, in timp ce modelele premium pot depasi 100 de lei, oferind durabilitate si izolare superioara." },
  { question: "care e diferenta intre termos si cutie termica bebelusi", answer: "Principala diferenta sta in izolarea termica. Un termos pentru mancare bebelusi (de obicei din inox, cu pereti dubli si vid) mentine mancarea calda sau rece mult mai mult timp (pana la 8-12 ore). O cutie termica simpla, fara vid, izoleaza mult mai slab, tinand mancarea in conditii doar 3-5 ore." },
  { question: "merita sa cumperi termos inox pentru bebelusi", answer: "Absolut! Termosurile din inox sunt cele mai recomandate pentru bebelusi datorita durabilitatii, rezistentei la coroziune si usurintei in curatare. Nu retin mirosuri si sunt sigure din punct de vedere al sanatatii, fiind o alegere excelenta pe termen lung." },
  { question: "ce capacitate trebuie sa aiba un termos pentru bebelusi", answer: "Capacitatea ideala pentru un termos pentru mancare bebelusi este intre 300ml si 500ml. Aceasta cantitate este suficienta pentru o masa completa a unui copil mic si nu face termosul prea greu sau incomod de transportat. Pentru calatorii lungi, 500ml poate fi mai potrivit." },
  { question: "cum curat corect termosul de mancare bebelusi", answer: "Cel mai bine este sa cureti termosul imediat dupa utilizare cu apa calda si detergent de vase, folosind o perie speciala pentru termosuri daca este nevoie. Asigura-te ca garnitura capacului este curata si bine asezata. Unele modele pot fi spalate in masina de spalat vase, dar verifica instructiunile producatorului." },
  { question: "cat timp tine mancarea calda un termos pentru copii", answer: "Un termos pentru mancare bebelusi de calitate, din inox si cu vid, poate tine mancarea calda intre 6 si 12 ore. Performanta exacta depinde de model, de cat de plin este termosul si de temperatura initiala a mancarii. Pentru o utilizare zilnica, asteapta-te la 4-8 ore de caldura eficienta." },
  { question: "unde gasesc termosuri bune pentru bebelusi in romania", answer: "Poti gasi termosuri bune pentru bebelusi in majoritatea magazinelor online mari din Romania (eMag, Noriel, Bebe Tei, Vivre), in magazinele fizice specializate pentru copii sau chiar in supermarketurile mai mari. Branduri precum Thermos, Beaba, Skip Hop sunt usor de gasit." },
  { question: "ce sa evit cand cumpar termos pentru copil", answer: "Evita termosurile foarte ieftine, din plastic de proasta calitate sau fara specificatii clare de izolare termica. Verifica intotdeauna sa fie BPA-free, sa aiba o garnitura de etansare buna si sa fie usor de curatat (preferabil cu gura larga). Nu te baza pe modele care promit timpi nerealisti de mentinere a temperaturii." }
];

const toc = [
  { title: "Termosul perfect pentru puiul tau: Pe asta mizez eu!", id: "termosul-perfect-pentru-puiul-tau-pe-asta-mizez-eu" },
  { title: "Top 4 Termosuri pentru Puii Tai: Cu Plusuri si Minusuri Oneste", id: "top-4-termosuri-pentru-puii-tai-cu-plusuri-si-minusuri-oneste" },
  { title: "Cum Alegi Termosul Perfect: Ghidul Mamei Practice", id: "cum-alegi-termosul-perfect-ghidul-mamei-practice" },
  { title: "Termos vs. Cutie Termica: Ce Alegi Pentru Puiul Tau?", id: "termos-vs-cutie-termica-ce-alegi-pentru-puiul-tau" },
  { title: "Greseli de Evitat si Trucuri de Mami Experimentata", id: "greseli-de-evitat-si-trucuri-de-mami-experimentata" },
  { title: "Termosuri Pentru Buzunarul Tau: Recomandari pe Bugete", id: "termosuri-pentru-buzunarul-tau-recomandari-pe-bugete" }
];

// Get all articles for similar articles component
const allArticles = keywordsData.completed.map(item => ({
  title: item.keyword.charAt(0).toUpperCase() + item.keyword.slice(1),
  slug: item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
  excerpt: item.excerpt || '',
  image: `/images/articles/${item.keyword.toLowerCase()
    .replace(/ă/g, 'a').replace(/â/g, 'a').replace(/î/g, 'i')
    .replace(/ș/g, 's').replace(/ț/g, 't')
    .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}.webp`,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

