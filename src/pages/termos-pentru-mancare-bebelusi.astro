export const frontmatter = {
  title: "Termos pentru mancare bebelusi",
  excerpt: "Cel mai bun termos pentru mancare bebelusi? Pentru mine, un termos bun e ala care tine mancarea calda ore bune, e usor de curatat si nu curge. Recomand din suflet modelele de la Thermos sau Beaba, cam astea mi s-au parut cele mai fiabile pe termen lung. Stai sa-ti zic si de ce.",
  image: "/images/articles/termos-pentru-mancare-bebelusi.webp",
  category: "Alimentatie si Nutritie Copii",
  categorySlug: "alimentatie-nutritie-copii",
  date: "2026-02-21T10:08:36.622Z",
  modifiedDate: "2026-02-21T10:08:36.622Z",
